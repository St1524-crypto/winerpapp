
SUPABASE_PROJECT_ID=replace_with_supabase_project_id
SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key
SUPABASE_URL=https://replace_with_project_ref.supabase.co
VITE_SUPABASE_PROJECT_ID=replace_with_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key
VITE_SUPABASE_URL=https://replace_with_project_ref.supabase.co

# Server-only. Only scheduled jobs may use this value as a Bearer token.
# Do not expose this to frontend code.
# Do not use SUPABASE_SERVICE_ROLE_KEY as a replacement.
CRON_SECRET=replace_with_random_long_secret

# Server-only. Required for admin/server operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# Server-only. Required only for Lovable AI/email features.
LOVABLE_API_KEY=replace_with_lovable_api_key
LOVABLE_SEND_URL=replace_with_lovable_send_url

# Server-only. Comma-separated origins allowed to call public AI endpoints.
# Example: https://example.com,https://www.example.com
AI_ALLOWED_ORIGINS=https://replace_with_public_site_origin

# Server-only. Per-origin/per-IP limit for public AI endpoint calls.
AI_RECRUIT_RATE_LIMIT_PER_MINUTE=10
